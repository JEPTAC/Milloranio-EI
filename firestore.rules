rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function validText(value, min, max) {
      return value is string && value.size() >= min && value.size() <= max;
    }

    function validRankingCreate() {
      let d = request.resource.data;
      return d.keys().hasOnly([
          'game', 'player', 'area', 'points', 'money', 'coins',
          'level', 'correct', 'wrong', 'jokes', 'lifelinesUsed', 'createdAt'
        ])
        && d.game == 'quien_quiere_ser_millonario_electro'
        && validText(d.player, 1, 40)
        && validText(d.area, 1, 60)
        && d.points is int && d.points >= 0 && d.points <= 2000000
        && d.money is int && d.money >= 0 && d.money <= 1000000
        && d.coins is int && d.coins >= 0 && d.coins <= 1000000
        && d.level is int && d.level >= 1 && d.level <= 13
        && d.correct is int && d.correct >= 0 && d.correct <= 13
        && d.wrong is int && d.wrong >= 0 && d.wrong <= 13
        && d.jokes is int && d.jokes >= 0 && d.jokes <= 20
        && d.lifelinesUsed is list && d.lifelinesUsed.size() <= 5
        && d.createdAt == request.time;
    }

    match /rankings/{entryId} {
      // Permite mostrar el ranking en la app.
      allow read: if true;

      // Permite crear puntajes desde el juego, con validación de campos.
      allow create: if validRankingCreate();

      // Evita que desde el navegador alguien edite o borre puntajes existentes.
      allow update, delete: if false;
    }

    // Todo lo demás queda cerrado.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
